{
  "name": "@mechago/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:railway": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:gis": "tsx scripts/enable-postgis.ts",
    "db:setup": "npm run db:gis && npm run db:migrate",
    "db:seed": "tsx --env-file=.env scripts/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "@hono/zod-openapi": "^0.18.0",
    "@scalar/hono-api-reference": "^0.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.71.1",
    "drizzle-orm": "^0.36.0",
    "firebase-admin": "^13.7.0",
    "hono": "^4.0.0",
    "ioredis": "^5.4.0",
    "jose": "^6.2.2",
    "mercadopago": "^2.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
