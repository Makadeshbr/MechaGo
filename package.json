{
  "name": "mechago",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "npm run test:run --workspace @mechago/api",
    "typecheck": "npm run build --workspace @mechago/shared && npm run build --workspace @mechago/api && npx tsc -p apps/pro/tsconfig.json --noEmit && npx tsc -p apps/cliente/tsconfig.json --noEmit",
    "start": "npm run railway:start",
    "start:api": "npm run start:railway --workspace @mechago/api",
    "lint": "turbo lint",
    "railway:build": "npm run build --workspace @mechago/shared && npm run build --workspace @mechago/api",
    "railway:start": "npm run start:railway --workspace @mechago/api",
    "db:generate": "cd apps/api && npx drizzle-kit generate",
    "db:migrate": "cd apps/api && npx drizzle-kit migrate",
    "db:studio": "cd apps/api && npx drizzle-kit studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "react-native-svg": "15.15.0"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0"
  }
}
